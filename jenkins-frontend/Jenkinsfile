pipeline {
    agent any

    tools {
        nodejs 'node18'
    }

    stages {

        stage('Clone Repository') {
            steps {
                echo 'Cloning repository...'
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('jenkins-frontend') {
                    sh 'npm install'
                }
            }
        }

        stage('Build React App') {
            steps {
                dir('jenkins-frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Success') {
            steps {
                echo 'React App Build Successful!'
            }
        }

    }
}